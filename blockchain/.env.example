# Optional private key for Ganache deploy. Use only local test accounts.
# Do not commit blockchain/.env.
PRIVATE_KEY=0xyour_ganache_or_hardhat_test_private_key

# Ganache GUI usually uses 7545. Hardhat node usually uses 8545.
GANACHE_URL=http://127.0.0.1:7545
LOCALHOST_RPC_URL=http://127.0.0.1:8545
